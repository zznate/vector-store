<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <groupId>io.github.zznate</groupId>
  <artifactId>vector-store-parent</artifactId>
  <version>0.1.0-SNAPSHOT</version>
  <packaging>pom</packaging>

  <name>vector-store-parent</name>
  <description>
    Multi-module parent for vector-store, a lightweight vector-database service
    backed by JVector with segments persisted on S3-compatible object storage.
  </description>
  <url>https://github.com/zznate/vector-store</url>

  <licenses>
    <license>
      <name>Apache License, Version 2.0</name>
      <url>https://www.apache.org/licenses/LICENSE-2.0.txt</url>
      <distribution>repo</distribution>
    </license>
  </licenses>

  <scm>
    <url>https://github.com/zznate/vector-store</url>
    <connection>scm:git:https://github.com/zznate/vector-store.git</connection>
    <developerConnection>scm:git:git@github.com:zznate/vector-store.git</developerConnection>
  </scm>

  <modules>
    <module>vector-store-core</module>
    <module>vector-store-api</module>
    <module>vector-store-engine</module>
    <module>vector-store-storage</module>
    <module>vector-store-metadata</module>
    <module>vector-store-app</module>
    <module>vector-store-datagen</module>
  </modules>

  <properties>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    <project.reporting.outputEncoding>UTF-8</project.reporting.outputEncoding>
    <maven.compiler.release>21</maven.compiler.release>

    <!-- Platform versions -->
    <quarkus.platform.group-id>io.quarkus.platform</quarkus.platform.group-id>
    <quarkus.platform.artifact-id>quarkus-bom</quarkus.platform.artifact-id>
    <quarkus.platform.version>3.33.1</quarkus.platform.version>

    <!-- Library versions -->
    <!-- TODO: move to JVector 4.0.0 GA when released; currently tracking rc.8 -->
    <jvector.version>4.0.0-rc.8</jvector.version>
    <jdbi.version>3.52.1</jdbi.version>
    <sqlite.jdbc.version>3.53.0.0</sqlite.jdbc.version>
    <quarkus.jdbc.sqlite.version>3.0.11</quarkus.jdbc.sqlite.version>
    <password4j.version>1.8.4</password4j.version>
    <uuid.creator.version>6.1.1</uuid.creator.version>
    <assertj.version>3.27.3</assertj.version>
    <aws.sdk.version>2.32.2</aws.sdk.version>
    <caffeine.version>3.2.0</caffeine.version>
    <roaringbitmap.version>1.3.0</roaringbitmap.version>
    <testcontainers.version>1.21.3</testcontainers.version>
    <mockito.version>5.14.2</mockito.version>

    <!-- Plugin versions -->
    <maven.compiler.plugin.version>3.13.0</maven.compiler.plugin.version>
    <maven.surefire.plugin.version>3.5.2</maven.surefire.plugin.version>
    <maven.failsafe.plugin.version>3.5.2</maven.failsafe.plugin.version>
    <maven.enforcer.plugin.version>3.5.0</maven.enforcer.plugin.version>
    <maven.jar.plugin.version>3.4.2</maven.jar.plugin.version>
    <build.helper.plugin.version>3.6.0</build.helper.plugin.version>

    <!--
      JVM flags required by JVector's Panama Vector API code path and by
      the foreign-memory L2 cache (Arena / MemorySegment). FFM is final
      in JDK 22 but preview in JDK 21, so the enable-preview flag is
      needed until we upgrade. Surefire and Failsafe both apply these so
      tests exercise both the SIMD and FFM paths. Runtime needs the same
      flags via JAVA_TOOL_OPTIONS / container ENTRYPOINT.
    -->
    <vectorstore.test.jvm.args>--add-modules=jdk.incubator.vector --enable-native-access=ALL-UNNAMED --enable-preview</vectorstore.test.jvm.args>

    <!-- Skip unnecessary steps in non-app modules by default -->
    <skipITs>false</skipITs>
  </properties>

  <dependencyManagement>
    <dependencies>
      <!-- Quarkus platform BOM -->
      <dependency>
        <groupId>${quarkus.platform.group-id}</groupId>
        <artifactId>${quarkus.platform.artifact-id}</artifactId>
        <version>${quarkus.platform.version}</version>
        <type>pom</type>
        <scope>import</scope>
      </dependency>

      <!-- JDBI BOM -->
      <dependency>
        <groupId>org.jdbi</groupId>
        <artifactId>jdbi3-bom</artifactId>
        <version>${jdbi.version}</version>
        <type>pom</type>
        <scope>import</scope>
      </dependency>

      <!-- AWS SDK v2 BOM (S3 and supporting artifacts) -->
      <dependency>
        <groupId>software.amazon.awssdk</groupId>
        <artifactId>bom</artifactId>
        <version>${aws.sdk.version}</version>
        <type>pom</type>
        <scope>import</scope>
      </dependency>

      <!-- Testcontainers BOM (MinIO integration tests) -->
      <dependency>
        <groupId>org.testcontainers</groupId>
        <artifactId>testcontainers-bom</artifactId>
        <version>${testcontainers.version}</version>
        <type>pom</type>
        <scope>import</scope>
      </dependency>

      <!-- Caffeine on-heap block cache -->
      <dependency>
        <groupId>com.github.ben-manes.caffeine</groupId>
        <artifactId>caffeine</artifactId>
        <version>${caffeine.version}</version>
      </dependency>

      <!-- RoaringBitmap pinned here for both phase 3 and the phase 4 tombstones -->
      <dependency>
        <groupId>org.roaringbitmap</groupId>
        <artifactId>RoaringBitmap</artifactId>
        <version>${roaringbitmap.version}</version>
      </dependency>

      <!-- Mockito for pure-unit tests with mocked S3Client etc. -->
      <dependency>
        <groupId>org.mockito</groupId>
        <artifactId>mockito-core</artifactId>
        <version>${mockito.version}</version>
        <scope>test</scope>
      </dependency>
      <dependency>
        <groupId>org.mockito</groupId>
        <artifactId>mockito-junit-jupiter</artifactId>
        <version>${mockito.version}</version>
        <scope>test</scope>
      </dependency>

      <!-- JVector -->
      <dependency>
        <groupId>io.github.jbellis</groupId>
        <artifactId>jvector</artifactId>
        <version>${jvector.version}</version>
      </dependency>

      <!-- SQLite JDBC driver (managed explicitly to stay current) -->
      <dependency>
        <groupId>org.xerial</groupId>
        <artifactId>sqlite-jdbc</artifactId>
        <version>${sqlite.jdbc.version}</version>
      </dependency>

      <!-- Quarkiverse SQLite Agroal integration -->
      <dependency>
        <groupId>io.quarkiverse.jdbc</groupId>
        <artifactId>quarkus-jdbc-sqlite</artifactId>
        <version>${quarkus.jdbc.sqlite.version}</version>
      </dependency>
      <dependency>
        <groupId>io.quarkiverse.jdbc</groupId>
        <artifactId>quarkus-jdbc-sqlite-deployment</artifactId>
        <version>${quarkus.jdbc.sqlite.version}</version>
      </dependency>

      <!-- Argon2id password hashing via password4j (pure Java, no JNI) -->
      <dependency>
        <groupId>com.password4j</groupId>
        <artifactId>password4j</artifactId>
        <version>${password4j.version}</version>
      </dependency>

      <!-- UUIDv7 generator for time-ordered segment IDs (RFC 9562) -->
      <dependency>
        <groupId>com.github.f4b6a3</groupId>
        <artifactId>uuid-creator</artifactId>
        <version>${uuid.creator.version}</version>
      </dependency>

      <!-- AssertJ for expressive test assertions -->
      <dependency>
        <groupId>org.assertj</groupId>
        <artifactId>assertj-core</artifactId>
        <version>${assertj.version}</version>
        <scope>test</scope>
      </dependency>

      <!-- Internal modules -->
      <dependency>
        <groupId>io.github.zznate</groupId>
        <artifactId>vector-store-core</artifactId>
        <version>${project.version}</version>
      </dependency>
      <dependency>
        <groupId>io.github.zznate</groupId>
        <artifactId>vector-store-api</artifactId>
        <version>${project.version}</version>
      </dependency>
      <dependency>
        <groupId>io.github.zznate</groupId>
        <artifactId>vector-store-engine</artifactId>
        <version>${project.version}</version>
      </dependency>
      <dependency>
        <groupId>io.github.zznate</groupId>
        <artifactId>vector-store-storage</artifactId>
        <version>${project.version}</version>
      </dependency>
      <dependency>
        <groupId>io.github.zznate</groupId>
        <artifactId>vector-store-metadata</artifactId>
        <version>${project.version}</version>
      </dependency>
    </dependencies>
  </dependencyManagement>

  <build>
    <pluginManagement>
      <plugins>
        <plugin>
          <groupId>${quarkus.platform.group-id}</groupId>
          <artifactId>quarkus-maven-plugin</artifactId>
          <version>${quarkus.platform.version}</version>
          <extensions>true</extensions>
          <executions>
            <execution>
              <goals>
                <goal>build</goal>
                <goal>generate-code</goal>
                <goal>generate-code-tests</goal>
              </goals>
            </execution>
          </executions>
        </plugin>

        <plugin>
          <groupId>org.apache.maven.plugins</groupId>
          <artifactId>maven-compiler-plugin</artifactId>
          <version>${maven.compiler.plugin.version}</version>
          <configuration>
            <release>${maven.compiler.release}</release>
            <parameters>true</parameters>
            <!--
              FFM (Arena / MemorySegment) is preview in JDK 21, final in
              JDK 22. Compiling with the enable-preview flag lets us use
              the L2 off-heap arena cache today; the same source compiles
              unchanged once we upgrade and can drop the flag.
            -->
            <compilerArgs>
              <arg>--enable-preview</arg>
            </compilerArgs>
          </configuration>
        </plugin>

        <plugin>
          <groupId>org.apache.maven.plugins</groupId>
          <artifactId>maven-surefire-plugin</artifactId>
          <version>${maven.surefire.plugin.version}</version>
          <configuration>
            <argLine>${vectorstore.test.jvm.args}</argLine>
            <systemPropertyVariables>
              <java.util.logging.manager>org.jboss.logmanager.LogManager</java.util.logging.manager>
              <maven.home>${maven.home}</maven.home>
            </systemPropertyVariables>
          </configuration>
        </plugin>

        <plugin>
          <groupId>org.apache.maven.plugins</groupId>
          <artifactId>maven-failsafe-plugin</artifactId>
          <version>${maven.failsafe.plugin.version}</version>
          <configuration>
            <argLine>${vectorstore.test.jvm.args}</argLine>
            <systemPropertyVariables>
              <java.util.logging.manager>org.jboss.logmanager.LogManager</java.util.logging.manager>
              <maven.home>${maven.home}</maven.home>
            </systemPropertyVariables>
          </configuration>
          <executions>
            <execution>
              <goals>
                <goal>integration-test</goal>
                <goal>verify</goal>
              </goals>
            </execution>
          </executions>
        </plugin>

        <plugin>
          <groupId>org.apache.maven.plugins</groupId>
          <artifactId>maven-jar-plugin</artifactId>
          <version>${maven.jar.plugin.version}</version>
        </plugin>
      </plugins>
    </pluginManagement>

    <plugins>
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-enforcer-plugin</artifactId>
        <version>${maven.enforcer.plugin.version}</version>
        <executions>
          <execution>
            <id>enforce-toolchain</id>
            <goals>
              <goal>enforce</goal>
            </goals>
            <configuration>
              <rules>
                <requireJavaVersion>
                  <version>[21,)</version>
                  <message>vector-store requires JDK 21 or later.</message>
                </requireJavaVersion>
                <requireMavenVersion>
                  <version>[3.9,)</version>
                  <message>vector-store requires Maven 3.9 or later.</message>
                </requireMavenVersion>
              </rules>
            </configuration>
          </execution>
        </executions>
      </plugin>
    </plugins>
  </build>

  <profiles>
    <profile>
      <id>native</id>
      <activation>
        <property>
          <name>native</name>
        </property>
      </activation>
      <properties>
        <quarkus.native.enabled>true</quarkus.native.enabled>
        <quarkus.native.additional-build-args>
          --add-modules=jdk.incubator.vector,--enable-native-access=ALL-UNNAMED
        </quarkus.native.additional-build-args>
      </properties>
    </profile>
  </profiles>
</project>
